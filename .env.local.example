# Supabase — récupérable dans Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — JAMAIS côté client, uniquement route handlers / server actions
SUPABASE_SERVICE_ROLE_KEY=

# Cron Vercel — protège /api/ping contre les appels non autorisés
CRON_SECRET=

# URL publique de l'app (pour liens d'invitation email, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
